    !
    !   RANDOM PATH
    !
    PROC randomPath()
        VAR speeddata randomPath_Speed := v100;
        
        ConfJ \On;
        ConfL \On;
        MoveJ randomPathTarget00,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveJ randomPathTarget10,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveL randomPathTarget20,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveL randomPathTarget30,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveL randomPathTarget40,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveL randomPathTarget50,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveL randomPathTarget40,randomPath_Speed,z100,tool0\WObj:=wobj0;
        MoveJ randomPathTarget60,randomPath_Speed,z100,tool0\WObj:=wobj0;
    ENDPROC
    
ENDMODULE