    CONST robtarget randomPathTarget30:=[[400,-274.159707825,500],[0.02613664,-0.606856313,0.794057525,-0.022692264],[-1,0,-2,0],[9E+09,9E+09,9E+09,9E+09,9E+09,9E+09]];
